# Mission Control — Environment Variables
# Copy this to .env and fill in values. Or just set these in your shell.
# All defaults are in config/settings.json — .env is optional and overrides.

# ── Hermes ────────────────────────────────────────────────────────────────────
# Where your Hermes Agent installation lives.
# Default: ~/.hermes
HERMES_HOME=~/.hermes

# Base URL for Hermes OpenAI-compatible API server.
# Default: http://127.0.0.1:8642
HERMES_API_BASE=http://127.0.0.1:8642

# ── Mission Control ───────────────────────────────────────────────────────────
# Port to serve the web dashboard on.
# Default: 8420
# MISSION_CONTROL_PORT=8420

# Log level: debug, info, warning, error.
# Default: info
# LOG_LEVEL=info
